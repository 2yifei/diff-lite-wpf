<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========== 颜色定义 ========== -->
    <Color x:Key="BgPrimary">#1E1E1E</Color>
    <Color x:Key="BgSecondary">#252526</Color>
    <Color x:Key="BgTertiary">#2D2D2D</Color>
    <Color x:Key="BgHover">#3A3A3A</Color>
    <Color x:Key="BgActive">#094771</Color>
    <Color x:Key="BorderColor">#3C3C3C</Color>
    <Color x:Key="BorderLight">#454545</Color>
    <Color x:Key="TextPrimary">#CCCCCC</Color>
    <Color x:Key="TextSecondary">#969696</Color>
    <Color x:Key="TextMuted">#6E6E6E</Color>
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="AccentHover">#1C8AE8</Color>
    <Color x:Key="SuccessGreen">#4EC9B0</Color>
    <Color x:Key="DangerRed">#F14C4C</Color>
    <Color x:Key="DiffAdded">#9BB95533</Color>
    <Color x:Key="DiffRemoved">#FF000033</Color>
    <Color x:Key="DiffAddedLine">#1E3A1E</Color>
    <Color x:Key="DiffRemovedLine">#3A1E1E</Color>
    <Color x:Key="StatusBarBg">#0078D4</Color>

    <!-- ========== 画刷 ========== -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}" />
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}" />
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="StatusBarBrush" Color="{StaticResource StatusBarBg}" />
    <SolidColorBrush x:Key="DiffAddedBgBrush" Color="{StaticResource DiffAddedLine}" />
    <SolidColorBrush x:Key="DiffRemovedBgBrush" Color="{StaticResource DiffRemovedLine}" />

    <!-- ========== 窗口样式 ========== -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgPrimaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Microsoft YaHei, Segoe UI, sans-serif" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ========== 按钮样式 ========== -->
    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#094771" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ========== 文本块样式 ========== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="PanelHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <!-- ========== 分隔条 ========== -->
    <Style x:Key="GridSplitterStyle" TargetType="GridSplitter">
        <Setter Property="Background" Value="{StaticResource BorderBrush}" />
        <Setter Property="Width" Value="4" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="ShowsPreview" Value="False" />
    </Style>

    <!-- ========== 菜单样式 ========== -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
